{
  "name": "Laravel Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "INSTALL_ZSH": "true",
      "USER_UID": "1000",
      "USER_GID": "1000",
      "PLAYWRIGHT_VERSION": "1.52.0"
    }
  },
  "mounts": [
    "source=${localWorkspaceFolderBasename}-node_modules,target=${containerWorkspaceFolder}/node_modules,type=volume",
    "source=${localWorkspaceFolderBasename}-vendor,target=${containerWorkspaceFolder}/vendor,type=volume",
    "source=${localWorkspaceFolderBasename}-claude,target=/home/vscode/.claude,type=volume"
  ],
  "workspaceFolder": "/home/vscode/project",
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/vscode/project,type=bind,consistency=delegated",
  "runArgs": [
    "--init",
    "--cpu-shares=512",
    "--shm-size=2g"
  ],
  "portsAttributes": {
    "8080": { "label": "Laravel App", "onAutoForward": "silent" },
    "8081": { "label": "Laravel App (Preset 2)", "onAutoForward": "silent" },
    "8082": { "label": "Laravel App (Preset 3)", "onAutoForward": "silent" },
    "5173": { "label": "Vite HMR", "onAutoForward": "silent", "visibility": "public" },
    "5174": { "label": "Vite HMR (Preset 2)", "onAutoForward": "silent", "visibility": "public" },
    "5175": { "label": "Vite HMR (Preset 3)", "onAutoForward": "silent", "visibility": "public" },
    "6080": { "label": "noVNC", "onAutoForward": "silent" },
    "6081": { "label": "noVNC (Preset 2)", "onAutoForward": "silent" },
    "6082": { "label": "noVNC (Preset 3)", "onAutoForward": "silent" }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  },
  "initializeCommand": "./.devcontainer/initializeCommand.sh",
  "postCreateCommand": "./.devcontainer/postCreateCommand.sh",
  "postAttachCommand": "./.devcontainer/postAttachCommand.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "bradlc.vscode-tailwindcss",
        "Vue.volar",
        "xdebug.php-debug",
        "amiralizadeh9480.laravel-extra-intellisense",
        "bmewburn.vscode-intelephense-client",
        "Anthropic.claude-code"
      ],
      "settings": {
        "task.autoDetect": "off",
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "dockerDashComposeVersion": "v2"
    }
  },
  "containerEnv": {
    "COMPOSE_PROJECT_NAME": "${localWorkspaceFolderBasename}",
    "CLAUDE_CODE_OAUTH_TOKEN": "${localEnv:CLAUDE_CODE_OAUTH_TOKEN}"
  }
}
